# =============================================================================
# yetaclaw — Environment Configuration
# Copy to .env and fill in your values.
# =============================================================================

# --- Data directory ---
# Absolute path on this machine — used for bind mount and agent container spawning
DATA_PATH=/opt/yetaclaw/data

# --- Mattermost ---
MATTERMOST_URL=https://your-mattermost-instance.com
MATTERMOST_TOKEN=your-bot-token-here

# --- Model ---
# Format: providerID/modelID
# Examples: anthropic/claude-sonnet-4-6  |  openrouter/anthropic/claude-sonnet-4-5
MODEL=anthropic/claude-sonnet-4-6

# --- OpenCode Auth ---
# Copy your credentials once into the data directory:
#   mkdir -p ${DATA_PATH}/opencode
#   cp ~/.local/share/opencode/auth.json ${DATA_PATH}/opencode/auth.json

# --- Initial Group Registration ---
# Mattermost channel the bot monitors on first startup.
# Get channel ID: System Console → Channels → find channel → copy ID from URL
# Format: mm:<channel-id>
INITIAL_GROUP_JID=mm:your-channel-id-here
INITIAL_GROUP_NAME=Main
INITIAL_GROUP_FOLDER=main
INITIAL_GROUP_TRIGGER=yetaclaw
INITIAL_GROUP_IS_MAIN=true

# --- Optional ---
LOG_LEVEL=info
